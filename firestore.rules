rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        request.auth.token.email == 'majidbhatti6312@gmail.com';
    }

    match /test/connection {
      allow read: if true;
    }

    match /settings/premium {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isSignedIn() && (isAdmin() || (resource.data.userId == request.auth.uid));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (isAdmin() || (resource.data.userId == request.auth.uid));
      allow delete: if isSignedIn() && (isAdmin() || (resource.data.userId == request.auth.uid));
    }

    match /templates/{templateId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    match /uploads/{uploadId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
